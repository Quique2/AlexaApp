{
  "expo": {
    "name": "Rrëy",
    "slug": "rrey-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "rrey",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0C0C0C",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C0C0C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rrey.inventory"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0C0C0C"
      },
      "package": "com.rrey.inventory"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "router": {
        "root": "."
      },
      "apiUrl": "https://alexaapp-production.up.railway.app/api",
      "eas": {
        "projectId": "896228fd-c932-4b68-a716-80ac277983aa"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/896228fd-c932-4b68-a716-80ac277983aa"
    }
  }
}
