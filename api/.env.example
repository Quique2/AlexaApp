# Copy this file to .env and fill in your values

# PostgreSQL connection string
# Local (Docker): postgresql://rrey:rrey_secret@localhost:5432/rrey_db
# Railway: provided automatically when you add a PostgreSQL service
DATABASE_URL="postgresql://rrey:rrey_secret@localhost:5432/rrey_db"

# Server port (Railway sets this automatically)
PORT=3000

# CORS — comma-separated origins allowed (e.g. your Expo web URL or localhost)
CORS_ORIGIN="http://localhost:8081,http://localhost:19006"
