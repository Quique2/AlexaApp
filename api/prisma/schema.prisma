generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MaterialType {
  LUPULO
  MALTA
  YEAST
  ADJUNTO
  OTRO
}

enum AlertStatus {
  RED
  YELLOW
  GREEN
  NONE
}

enum ActionStatus {
  ORDER_NOW
  ORDER_SOON
  COVERED
  OK
}

enum OrderStatus {
  PENDING
  IN_TRANSIT
  RECEIVED_COMPLETE
  RECEIVED_PARTIAL
  CANCELLED
}

enum PaymentMethod {
  TRANSFER
  SUPPLIER_CREDIT
  CASH
  CARD
  OTHER
}

enum ReceptionCondition {
  GOOD
  REGULAR
  DAMAGED
  INCOMPLETE
  EXPIRED
}

enum Role {
  DEVELOPER
  SUPERVISOR
  OPERATOR
  TRANSPORTER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BlockType {
  EMAIL
  IP
}

model Supplier {
  id                    String     @id
  name                  String
  country               String?
  materialType          String?
  daysToOrder           Int        @default(7)
  estimatedDeliveryDays Int        @default(7)
  minOrderQuantity      Float?
  minOrderUnit          String?
  hasCredit             Boolean    @default(false)
  notes                 String?
  materials             Material[]
  orders                Order[]
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@map("suppliers")
}

model Material {
  id           String                 @id
  name         String
  type         MaterialType
  brand        String?
  unit         String
  unitPrice    Float                  @default(0)
  priceUnit    String?
  supplierId   String?
  supplier     Supplier?              @relation(fields: [supplierId], references: [id])
  inventory    Inventory?
  orders       Order[]
  recipeLines  RecipeLine[]
  requirements ProductionRequirement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("materials")
}

model RecipeLine {
  id          String   @id @default(uuid())
  beerStyle   String
  materialId  String
  material    Material @relation(fields: [materialId], references: [id])
  qtyPerBatch Float
  notes       String?
  createdAt   DateTime @default(now())

  @@unique([beerStyle, materialId])
  @@map("recipe_lines")
}

model Inventory {
  id                 String                 @id @default(uuid())
  materialId         String                 @unique
  material           Material               @relation(fields: [materialId], references: [id])
  currentStock       Float                  @default(0)
  reservedStock      Float                  @default(0)
  dailyConsumption   Float                  @default(0)
  reorderPointDays   Int                    @default(7)
  alertStatus        AlertStatus            @default(NONE)
  isCritical         Boolean                @default(false)
  quantityToOrder    Float                  @default(0)
  estimatedOrderCost Float                  @default(0)
  notes              String?
  requirements       ProductionRequirement[]
  updatedAt          DateTime               @updatedAt

  @@map("inventory")
}

model ProductionPlan {
  id               String                 @id @default(uuid())
  productionDate   DateTime
  style            String
  plannedBatches   Int                    @default(1)
  maltKgPerBatch   Float                  @default(0)
  hopKgPerBatch    Float                  @default(0)
  yeastGPerBatch   Float                  @default(0)
  totalMaltKg      Float                  @default(0)
  totalHopKg       Float                  @default(0)
  totalYeastG      Float                  @default(0)
  notes            String?
  orderedAt        DateTime?
  approvalStatus   ApprovalStatus         @default(PENDING)
  productionStatus ProductionStatus       @default(PENDING)
  approvedById     String?
  approvedBy       User?                  @relation("PlanApprovedBy", fields: [approvedById], references: [id])
  approvedAt       DateTime?
  rejectedById     String?
  rejectedBy       User?                  @relation("PlanRejectedBy", fields: [rejectedById], references: [id])
  rejectedAt       DateTime?
  rejectionReason  String?
  hasMissingPrices Boolean                @default(false)
  estimatedCost    Float                  @default(0)
  createdById      String?
  createdBy        User?                  @relation("PlanCreatedBy", fields: [createdById], references: [id])
  requirements     ProductionRequirement[]
  orders           Order[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@map("production_plans")
}

model ProductionRequirement {
  id               String          @id @default(uuid())
  productionPlanId String
  productionPlan   ProductionPlan  @relation(fields: [productionPlanId], references: [id], onDelete: Cascade)
  inventoryId      String
  inventory        Inventory       @relation(fields: [inventoryId], references: [id])
  materialId       String
  material         Material        @relation(fields: [materialId], references: [id])
  requiredQuantity Float
  reservedQuantity Float           @default(0)
  missingQuantity  Float           @default(0)
  isCritical       Boolean         @default(false)
  actionStatus     ActionStatus    @default(OK)
  linkedOrderId    String?
  linkedOrder      Order?          @relation("RequirementOrder", fields: [linkedOrderId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([productionPlanId, materialId])
  @@map("production_requirements")
}

model Order {
  id                   String                 @id @default(uuid())
  folio                String                 @unique
  orderDate            DateTime
  materialId           String
  material             Material               @relation(fields: [materialId], references: [id])
  supplierId           String?
  supplier             Supplier?              @relation(fields: [supplierId], references: [id])
  productionPlanId     String?
  productionPlan       ProductionPlan?        @relation(fields: [productionPlanId], references: [id], onDelete: SetNull)
  orderedQuantity      Float
  totalPaid            Float?
  paymentMethod        PaymentMethod?
  estimatedArrivalDate DateTime?
  status               OrderStatus            @default(PENDING)
  month                String
  notes                String?
  receptions           Reception[]
  linkedRequirements   ProductionRequirement[] @relation("RequirementOrder")
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@map("orders")
}

model Reception {
  id               String             @id @default(uuid())
  receptionDate    DateTime
  orderId          String
  order            Order              @relation(fields: [orderId], references: [id])
  receivedQuantity Float
  condition        ReceptionCondition @default(GOOD)
  isConforming     Boolean            @default(true)
  batchLot         String?
  receivedBy       String?
  notes            String?
  createdAt        DateTime           @default(now())

  @@map("receptions")
}

model JITConfig {
  id                 Int      @id @default(1)
  workingDaysPerWeek Int      @default(5)
  maxDaysRawMaterial Int      @default(7)
  hopCoverageDays    Int      @default(90)
  yeastCoverageDays  Int      @default(15)
  safetyBufferDays   Int      @default(1)
  avgDailyProduction Float    @default(1)
  updatedAt          DateTime @updatedAt

  @@map("jit_config")
}

model User {
  id            String           @id @default(uuid())
  email         String           @unique
  passwordHash  String
  name          String?
  role          Role             @default(OPERATOR)
  isActive      Boolean          @default(true)
  createdById   String?
  createdBy     User?            @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers  User[]           @relation("UserCreatedBy")
  sessions      UserSession[]
  approvedPlans ProductionPlan[] @relation("PlanApprovedBy")
  rejectedPlans ProductionPlan[] @relation("PlanRejectedBy")
  createdPlans  ProductionPlan[] @relation("PlanCreatedBy")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("users")
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@map("user_sessions")
}

model BlockedEntity {
  id        String    @id @default(uuid())
  type      BlockType
  value     String
  reason    String?
  createdAt DateTime  @default(now())

  @@unique([type, value])
  @@map("blocked_entities")
}
